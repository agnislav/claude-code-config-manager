{
  "name": "claude-code-config-manager",
  "displayName": "Claude Code Config Manager",
  "description": "Visual config viewer and editor for Claude Code settings — scope-aware TreeView with override detection, inline editing, and file watching.",
  "version": "0.7.0",
  "publisher": "agnislav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agnislav/claude-code-config-manager"
  },
  "icon": "icon-v3.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "config",
    "settings",
    "configuration"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-config",
          "title": "Claude Code Config Manager",
          "icon": "resources/icons/icon-small.svg"
        }
      ]
    },
    "views": {
      "claude-config": [
        {
          "id": "claudeConfigTree",
          "name": "Configuration",
          "icon": "resources/icons/icon-small.svg",
          "contextualTitle": "Claude Code Configuration"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeConfig.refresh",
        "title": "Refresh Config",
        "category": "Claude Config",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeConfig.openFile",
        "title": "Open Config File",
        "category": "Claude Config",
        "icon": "$(go-to-file)"
      },
      {
        "command": "claudeConfig.addPermissionRule",
        "title": "Add Permission Rule",
        "category": "Claude Config",
        "icon": "$(add)"
      },
      {
        "command": "claudeConfig.addEnvVar",
        "title": "Add Environment Variable",
        "category": "Claude Config",
        "icon": "$(add)"
      },
      {
        "command": "claudeConfig.addMcpServer",
        "title": "Add MCP Server",
        "category": "Claude Config",
        "icon": "$(add)"
      },
      {
        "command": "claudeConfig.addHook",
        "title": "Add Hook",
        "category": "Claude Config",
        "icon": "$(add)"
      },
      {
        "command": "claudeConfig.editValue",
        "title": "Edit Value",
        "category": "Claude Config",
        "icon": "$(edit)"
      },
      {
        "command": "claudeConfig.deleteItem",
        "title": "Delete",
        "category": "Claude Config",
        "icon": "$(trash)"
      },
      {
        "command": "claudeConfig.moveToScope",
        "title": "Move to Scope...",
        "category": "Claude Config",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "claudeConfig.togglePlugin",
        "title": "Toggle Plugin",
        "category": "Claude Config"
      },
      {
        "command": "claudeConfig.createConfigFile",
        "title": "Create Config File",
        "category": "Claude Config",
        "icon": "$(new-file)"
      },
      {
        "command": "claudeConfig.revealInFile",
        "title": "Reveal in Config File",
        "category": "Claude Config"
      },
      {
        "command": "claudeConfig.deletePlugin",
        "title": "Delete Plugin",
        "category": "Claude Config",
        "icon": "$(trash)"
      },
      {
        "command": "claudeConfig.copyPluginToScope",
        "title": "Copy to Scope...",
        "category": "Claude Config",
        "icon": "$(add)"
      },
      {
        "command": "claudeConfig.openPluginReadme",
        "title": "Open README",
        "category": "Claude Config",
        "icon": "$(book)"
      },
      {
        "command": "claudeConfig.copySettingToScope",
        "title": "Copy to Scope...",
        "category": "Claude Config",
        "icon": "$(add)"
      },
      {
        "command": "claudeConfig.copyPermissionToScope",
        "title": "Copy to Scope...",
        "category": "Claude Config",
        "icon": "$(add)"
      },
      {
        "command": "claudeConfig.filterSections",
        "title": "Filter Sections",
        "category": "Claude Config",
        "icon": "$(filter)"
      },
      {
        "command": "claudeConfig.filterSections.active",
        "title": "Filter Sections",
        "category": "Claude Config",
        "icon": "$(filter-filled)"
      },
      {
        "command": "claudeConfig.toggleUserLock",
        "title": "Toggle User Scope Lock",
        "category": "Claude Config"
      },
      {
        "command": "claudeConfig.lockUserScope",
        "title": "Lock User Scope",
        "category": "Claude Config",
        "icon": "$(unlock)"
      },
      {
        "command": "claudeConfig.unlockUserScope",
        "title": "Unlock User Scope",
        "category": "Claude Config",
        "icon": "$(lock)"
      },
      {
        "command": "claudeConfig.collapseAll",
        "title": "Collapse All",
        "category": "Claude Config",
        "icon": "$(collapse-all)"
      },
      {
        "command": "claudeConfig.expandAll",
        "title": "Expand All",
        "category": "Claude Config",
        "icon": "$(expand-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeConfig.lockUserScope",
          "when": "view == claudeConfigTree && !claudeConfig_userScope_locked",
          "group": "navigation@0"
        },
        {
          "command": "claudeConfig.unlockUserScope",
          "when": "view == claudeConfigTree && claudeConfig_userScope_locked",
          "group": "navigation@0"
        },
        {
          "command": "claudeConfig.filterSections",
          "when": "view == claudeConfigTree && !claudeConfig_filterActive",
          "group": "navigation@1"
        },
        {
          "command": "claudeConfig.filterSections.active",
          "when": "view == claudeConfigTree && claudeConfig_filterActive",
          "group": "navigation@1"
        },
        {
          "command": "claudeConfig.collapseAll",
          "when": "view == claudeConfigTree",
          "group": "navigation@2"
        },
        {
          "command": "claudeConfig.expandAll",
          "when": "view == claudeConfigTree",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeConfig.openFile",
          "when": "view == claudeConfigTree && viewItem =~ /^scope\\./",
          "group": "navigation"
        },
        {
          "command": "claudeConfig.editValue",
          "when": "view == claudeConfigTree && viewItem =~ /\\.editable/ && viewItem =~ /setting|envVar|sandboxProperty/",
          "group": "1_edit"
        },
        {
          "command": "claudeConfig.deleteItem",
          "when": "view == claudeConfigTree && viewItem =~ /\\.editable/ && viewItem =~ /permissionRule|envVar|hookEntry|mcpServer|plugin|setting|sandboxProperty/",
          "group": "1_edit"
        },
        {
          "command": "claudeConfig.moveToScope",
          "when": "view == claudeConfigTree && viewItem =~ /\\.editable/ && viewItem =~ /permissionRule|envVar|plugin|setting/",
          "group": "2_move"
        },
        {
          "command": "claudeConfig.addEnvVar",
          "when": "view == claudeConfigTree && viewItem =~ /^section\\.env\\.editable/",
          "group": "3_add"
        },
        {
          "command": "claudeConfig.addMcpServer",
          "when": "view == claudeConfigTree && viewItem =~ /^section\\.mcpServers\\.editable/",
          "group": "3_add"
        },
        {
          "command": "claudeConfig.addHook",
          "when": "view == claudeConfigTree && viewItem =~ /^section\\.hooks\\.editable|^hookEvent/",
          "group": "3_add"
        },
        {
          "command": "claudeConfig.togglePlugin",
          "when": "view == claudeConfigTree && viewItem =~ /^plugin\\.editable/",
          "group": "1_edit"
        },
        {
          "command": "claudeConfig.createConfigFile",
          "when": "view == claudeConfigTree && viewItem =~ /^scope\\..+\\.missing/",
          "group": "navigation"
        },
        {
          "command": "claudeConfig.openPluginReadme",
          "when": "view == claudeConfigTree && viewItem =~ /^plugin\\./",
          "group": "inline@0"
        },
        {
          "command": "claudeConfig.moveToScope",
          "when": "view == claudeConfigTree && viewItem =~ /^plugin\\.editable/ && false",
          "group": "inline@1"
        },
        {
          "command": "claudeConfig.copyPluginToScope",
          "when": "view == claudeConfigTree && viewItem =~ /^plugin\\.editable/ && false",
          "group": "inline@2"
        },
        {
          "command": "claudeConfig.deletePlugin",
          "when": "view == claudeConfigTree && viewItem =~ /^plugin\\.editable/ && false",
          "group": "inline@3"
        },
        {
          "command": "claudeConfig.editValue",
          "when": "view == claudeConfigTree && viewItem =~ /\\.editable/ && viewItem =~ /envVar|sandboxProperty/ && false",
          "group": "inline@1"
        },
        {
          "command": "claudeConfig.moveToScope",
          "when": "view == claudeConfigTree && viewItem =~ /^envVar\\.editable/",
          "group": "inline@0"
        },
        {
          "command": "claudeConfig.moveToScope",
          "when": "view == claudeConfigTree && viewItem =~ /^permissionRule\\.editable/",
          "group": "inline@0"
        },
        {
          "command": "claudeConfig.copyPermissionToScope",
          "when": "view == claudeConfigTree && viewItem =~ /^permissionRule\\.editable/",
          "group": "inline@1"
        },
        {
          "command": "claudeConfig.moveToScope",
          "when": "view == claudeConfigTree && viewItem =~ /^setting\\.editable/",
          "group": "inline@0"
        },
        {
          "command": "claudeConfig.copySettingToScope",
          "when": "view == claudeConfigTree && viewItem =~ /^setting\\.editable/",
          "group": "inline@1"
        },
        {
          "command": "claudeConfig.deleteItem",
          "when": "view == claudeConfigTree && viewItem =~ /\\.editable/ && viewItem =~ /permissionRule|envVar|hookEntry|mcpServer|setting|sandboxProperty/",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "claudeConfig.editValue",
          "when": "false"
        },
        {
          "command": "claudeConfig.deleteItem",
          "when": "false"
        },
        {
          "command": "claudeConfig.moveToScope",
          "when": "false"
        },
        {
          "command": "claudeConfig.togglePlugin",
          "when": "false"
        },
        {
          "command": "claudeConfig.createConfigFile",
          "when": "false"
        },
        {
          "command": "claudeConfig.revealInFile",
          "when": "false"
        },
        {
          "command": "claudeConfig.deletePlugin",
          "when": "false"
        },
        {
          "command": "claudeConfig.copyPluginToScope",
          "when": "false"
        },
        {
          "command": "claudeConfig.openPluginReadme",
          "when": "false"
        },
        {
          "command": "claudeConfig.copySettingToScope",
          "when": "false"
        },
        {
          "command": "claudeConfig.copyPermissionToScope",
          "when": "false"
        },
        {
          "command": "claudeConfig.filterSections.active",
          "when": "false"
        },
        {
          "command": "claudeConfig.lockUserScope",
          "when": "false"
        },
        {
          "command": "claudeConfig.unlockUserScope",
          "when": "false"
        },
        {
          "command": "claudeConfig.collapseAll",
          "when": "false"
        },
        {
          "command": "claudeConfig.expandAll",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "build": "node esbuild.js --production",
    "test": "tsc -p tsconfig.test.json && node ./out/test/runTests.js",
    "lint": "eslint src/ --ext .ts",
    "package": "vsce package",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  }
}
