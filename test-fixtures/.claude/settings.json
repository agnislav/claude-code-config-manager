{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "NODE_ENV": "development",
    "API_BASE_URL": "https://api.example.com/v1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "network": {
      "allowedDomains": ["api.example.com", "cdn.example.com"],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": ["/tmp", "/var/cache"],
      "denyRead": ["/etc/secrets"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Pre-edit check passed'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Review this shell command for safety before executing"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Verify that unit tests still pass after this code change"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(LC_ALL=C find:*)",
      "Bash(LC_ALL=C xargs grep:*)",
      "Bash(TZ=UTC yarn jest:*)",
      "Bash(TZ=UTC yarn test)",
      "Bash(TZ=UTC yarn test:*)",
      "Bash(adb -s emulator-5554 emu avd:*)",
      "Bash(adb -s emulator-5554 shell input keyevent:*)",
      "Bash(adb devices:*)",
      "Bash(adb shell pm list packages:*)",
      "Bash(adb shell:*)",
      "Bash(adb wait-for-device:*)",
      "Bash(awk:*)",
      "Bash(bd create:*)",
      "Bash(bd list:*)",
      "Bash(bd ready:*)",
      "Bash(bd show:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(emulator:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git merge-base:*)",
      "Bash(git mv:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(maestro:*)",
      "Bash(maestro test:*)",
      "Bash(npm outdated:*)",
      "Bash(npm view:*)",
      "Bash(npx knip:*)",
      "Bash(npx react-native log-ios:*)",
      "Bash(npx repomix:*)",
      "Bash(npx tsc:*)",
      "Bash(perl -i -pe:*)",
      "Bash(sort:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(tree:*)",
      "Bash(xargs sed:*)",
      "Bash(xargs:*)",
      "Bash(yarn --version)",
      "Bash(yarn eslint:*)",
      "Bash(yarn format:check:*)",
      "Bash(yarn gen:bundle:*)",
      "Bash(yarn gen:repomix)",
      "Bash(yarn install)",
      "Bash(yarn jest:*)",
      "Bash(yarn knip)",
      "Bash(yarn knip:*)",
      "Bash(yarn lint:check:*)",
      "Bash(yarn lint:fix:*)",
      "Bash(yarn list:*)",
      "Bash(yarn prebuild:dev:*)",
      "Bash(yarn prebuild:prod*)",
      "Bash(yarn test:*)",
      "Bash(yarn test:coverage:*)",
      "Bash(yarn test:unit)",
      "Bash(yarn test:unit:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn typecheck:*)",
      "Bash(yarn why:*)",
      "Skill(beads:comments)",
      "Skill(beads:ready)",
      "Skill(review-code)",
      "Skill(update-branch)",
      "SlashCommand(/check-ios-simulator)",
      "SlashCommand(/check-unit-tests)",
      "SlashCommand(/new-branch:*)",
      "SlashCommand(/slack-pr-review:*)",
      "mcp__asana__asana_get_project",
      "mcp__asana__asana_get_project_sections",
      "mcp__asana__asana_get_projects",
      "mcp__asana__asana_get_projects_for_workspace",
      "mcp__asana__asana_get_task",
      "mcp__asana__asana_get_tasks",
      "mcp__asana__asana_get_user",
      "mcp__asana__asana_list_workspaces",
      "mcp__asana__asana_search_tasks",
      "mcp__asana__asana_typeahead_search",
      "mcp__context7__get-library-docs",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__figma__get_design_context",
      "mcp__figma__get_metadata",
      "mcp__figma__get_screenshot",
      "mcp__mcp-sequentialthinking-tools__sequentialthinking_tools",
      "mcp__repomix__attach_packed_output",
      "mcp__repomix__grep_repomix_output",
      "mcp__repomix__pack_remote_repository"
    ],
    "deny": [],
    "ask": [
      "Bash(git checkout:*)"
    ]
  }
}
