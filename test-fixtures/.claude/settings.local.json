  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Local pre-bash check'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git pull:*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && yarn gen:repomix > /tmp/repomix-update.log 2>&1 &"
          }
        ]
      },
      {
        "matcher": "Bash(git merge:*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && yarn gen:repomix > /tmp/repomix-update.log 2>&1 &"
          }
        ]
      },
      {
        "matcher": "Bash(git rebase:*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && yarn gen:repomix > /tmp/repomix-update.log 2>&1 &"
          }
        ]
      }
    ]
  }
