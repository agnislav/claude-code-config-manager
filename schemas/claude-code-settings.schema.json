{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Settings",
  "description": "Configuration schema for Claude Code settings files (.claude/settings.json, .claude/settings.local.json, etc.)",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "permissions": {
      "type": "object",
      "description": "Permission rules controlling tool access",
      "properties": {
        "allow": {
          "type": "array",
          "description": "Tools and specifiers that are always allowed",
          "items": { "type": "string" }
        },
        "deny": {
          "type": "array",
          "description": "Tools and specifiers that are always denied",
          "items": { "type": "string" }
        },
        "ask": {
          "type": "array",
          "description": "Tools and specifiers that require user confirmation",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "env": {
      "type": "object",
      "description": "Environment variables passed to Claude Code",
      "additionalProperties": { "type": "string" }
    },
    "hooks": {
      "type": "object",
      "description": "Lifecycle hooks triggered during tool execution",
      "properties": {
        "PreToolUse": { "$ref": "#/definitions/hookEntries" },
        "PostToolUse": { "$ref": "#/definitions/hookEntries" },
        "Notification": { "$ref": "#/definitions/hookEntries" },
        "Stop": { "$ref": "#/definitions/hookEntries" },
        "SubagentStop": { "$ref": "#/definitions/hookEntries" }
      },
      "additionalProperties": false
    },
    "sandbox": {
      "type": "object",
      "description": "Sandbox configuration for Claude Code execution environment",
      "properties": {
        "permissions": {
          "type": "object",
          "additionalProperties": true
        },
        "network": {
          "type": "object",
          "properties": {
            "allowedHosts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "blockedHosts": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "enabledPlugins": {
      "type": "object",
      "description": "Plugins and their enabled/disabled state",
      "additionalProperties": { "type": "boolean" }
    },
    "model": {
      "type": "string",
      "description": "Default model to use"
    },
    "smallFastModel": {
      "type": "string",
      "description": "Model for lightweight/fast operations"
    },
    "outputStyle": {
      "type": "string",
      "description": "Output style for Claude Code responses"
    },
    "apiKeyHelper": {
      "type": "string",
      "description": "Command to retrieve the API key"
    },
    "includeCoAuthoredBy": {
      "type": "boolean",
      "description": "Whether to include co-authored-by in git commits"
    },
    "trustWorkspaceConfig": {
      "type": "boolean",
      "description": "Whether to trust workspace-level configuration"
    }
  },
  "definitions": {
    "hookEntries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "matcher": {
            "type": "string",
            "description": "Regex pattern to match tool names (e.g. 'Bash', 'Edit|Write')"
          },
          "hooks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["command", "url"],
                  "description": "Hook type"
                },
                "command": {
                  "type": "string",
                  "description": "Shell command to execute"
                },
                "url": {
                  "type": "string",
                  "description": "URL to call"
                },
                "timeout": {
                  "type": "number",
                  "description": "Timeout in milliseconds"
                }
              },
              "required": ["type"]
            }
          }
        },
        "required": ["hooks"]
      }
    }
  }
}
